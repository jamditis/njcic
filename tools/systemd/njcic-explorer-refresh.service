[Unit]
Description=Refresh NJCIC grantee explorer data from Airtable
After=network-online.target
Wants=network-online.target
# Don't swamp the journal if something goes wrong and it fails repeatedly.
# (These directives only take effect in [Unit] — systemd silently ignores
# them when placed under [Service].)
StartLimitIntervalSec=600
StartLimitBurst=3

[Service]
Type=oneshot
User=jamditis
Group=jamditis
# Refuse to run if a previous invocation is still going
ExecStartPre=/bin/bash -c 'pgrep -fx "/bin/bash /home/jamditis/projects/njcic/tools/refresh_explorer.sh" && exit 1 || exit 0'
ExecStart=/bin/bash /home/jamditis/projects/njcic/tools/refresh_explorer.sh
# Allow sudo cp (already passwordless on this host per CLAUDE.md)
StandardOutput=journal
StandardError=journal
